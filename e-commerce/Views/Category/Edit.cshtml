@model e_commerce.Models.Category

<h1>
    <span class="me-2">
        Edit Category
    </span>
    <span>
        <i class="bi bi-tools"></i>
    </span>
</h1>

<form method="post">
    <fieldset>
        <input type="hidden" asp-for="Id" />
        <div>
            <label class="form-label mt-4">Name</label>
            <input class="form-control" placeholder="Enter Name" asp-for="Name">
            <span asp-validation-for="Name" class="text-danger mt-1"></span>
        </div>
        <div>
            <label class="form-label mt-4">Display Order</label>
            <input class="form-control" placeholder="Enter Display Order" asp-for="DisplayOrder">
            <span asp-validation-for="DisplayOrder" class="text-danger mt-1"></span>
        </div>
        <div class="mt-4">
            <button type="submit" class="btn btn-primary me-2">Submit</button>
            <a class="btn btn-light" asp-action="Index">Back to list</a>
        </div>
    </fieldset>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}