@model List<e_commerce.Models.Category>

@* Using Temp Data to show the success message *@
@* @if(TempData["success"] != null){
    <h1>@TempData["success"]</h1>
} *@

<partial name="_Notification" />

<div>
    <div class="d-flex justify-content-between">
        <h1>
            <span class="me-2">
                Category List
            </span>
            <i class="bi bi-emoji-sunglasses"></i>
        </h1>
        <a class="btn btn-dark text-white text-center align-content-center rounded-1" asp-action="Create">
            <span class="me-2">
                Create Category
            </span>
            <i class="bi bi-balloon-fill"></i>
        </a>
    </div>
    <div class="mt-5">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Display Order</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach(Category category in Model)
                {
                    <tr>
                        <td>@category.Name</td>
                        <td>@category.DisplayOrder</td>
                        <td>
                            <a asp-action="Edit" class="btn btn-outline-success rounded-2 me-2" asp-route-id="@category.Id">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <a class="btn btn-outline-danger rounded-2" asp-action="Delete" asp-route-id="@category.Id">
                                <i class="bi bi-trash3"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>