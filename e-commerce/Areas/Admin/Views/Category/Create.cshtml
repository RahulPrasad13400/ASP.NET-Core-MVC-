@model e_commerce.Models.Category


<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="text-white py-2">
                    <span class="me-2">
                        Create Category
                    </span>
                    <span>
                        <i class="bi bi-xbox"></i>
                    </span>
                </h1>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form method="post" class="row">
            <fieldset>

                @* To show all the errors, asp-validation-summary="All" shows all the validation errors  *@
                <div asp-validation-summary="All" class="text-danger"></div>

                <div>
                    <label class="form-label mt-4">Name</label>
                    <input class="form-control" placeholder="Enter Name" asp-for="Name">
                    <span asp-validation-for="Name" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">Display Order</label>
                    <input class="form-control" placeholder="Enter Display Order" asp-for="DisplayOrder">
                    <span asp-validation-for="DisplayOrder" class="text-danger mt-1"></span>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary me-2">Submit</button>
                    <a class="btn btn-light" asp-action="Index">Back to list</a>
                </div>
            </fieldset>
        </form>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}