@model ProductVM


<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="text-white py-2">
                    <span class="me-2">
                        Create Product
                    </span>
                    <span>
                        <i class="bi bi-xbox"></i>
                    </span>
                </h1>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form method="post" class="row">
            <fieldset>

                @* To show all the errors, asp-validation-summary="All" shows all the validation errors  *@
                <div asp-validation-summary="All" class="text-danger"></div>

                <div>
                    <label class="form-label mt-4">Title</label>
                    <input class="form-control" type="text" placeholder="Enter Name" asp-for="Product.Title">
                    <span asp-validation-for="Product.Title" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">Author</label>
                    <input class="form-control" type="text" placeholder="Enter Author" asp-for="Product.Author">
                    <span asp-validation-for="Product.Author" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">Description</label>
                    <textarea class="form-control" type="text" placeholder="Enter Description" asp-for="Product.Description"></textarea>
                </div>
                <div>
                    <label class="form-label mt-4">ISBN</label>
                    <input class="form-control" type="text" placeholder="Enter ISBN" asp-for="Product.ISBN" />
                    <span asp-validation-for="Product.ISBN" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">List Price</label>
                    <input class="form-control" type="number" placeholder="Enter the List Price" asp-for="Product.ListPrice" />
                    <span asp-validation-for="Product.ListPrice" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">Price 1-50</label>
                    <input type="number" class="form-control" placeholder="Enter the 1-50 Price" asp-for="Product.Price" />
                    <span asp-validation-for="Product.Price" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">Price 50+</label>
                    <input type="number" class="form-control" placeholder="Enter the 50+ Price" asp-for="Product.Price50" />
                    <span asp-validation-for="Product.Price50" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">Price 100+</label>
                    <input type="number" class="form-control" placeholder="Enter the 100 Price" asp-for="Product.Price100" />
                    <span asp-validation-for="Product.Price100" class="text-danger mt-1"></span>
                </div>
                <div>
                    @* ViewBag
                    <select asp-for="CategoryId" asp-items="ViewBag.CategoryList" class="form-select mt-4 w-100 py-2">
                        <option>Select Category</option>
                    </select> *@
                    
                    @* ViewData *@
                    @* <select asp-for="CategoryId" asp-items="@(ViewData["CategoryList"] as IEnumerable<SelectListItem>)" 
                        class="form-select mt-4 w-100 py-2">
                        <option>Select Category</option>
                    </select> *@

                    <select asp-for="Product.CategoryId" asp-items="@Model.CategoryList" 
                        class="form-select mt-4 w-100 py-2">
                        <option>Select Category</option>
                    </select>

                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary me-2">Submit</button>
                    <a class="btn btn-light" asp-action="Index">Back to list</a>
                </div>
            </fieldset>
        </form>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}