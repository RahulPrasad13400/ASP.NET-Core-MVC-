@model e_commerce.Models.Models.Product


<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="text-white py-2">
                    <span class="me-2">
                        Create Product
                    </span>
                    <span>
                        <i class="bi bi-xbox"></i>
                    </span>
                </h1>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form method="post" class="row">
            <fieldset>

                @* To show all the errors, asp-validation-summary="All" shows all the validation errors  *@
                <div asp-validation-summary="All" class="text-danger"></div>

                <div>
                    <label class="form-label mt-4">Title</label>
                    <input class="form-control" type="text" placeholder="Enter Name" asp-for="Title">
                    <span asp-validation-for="Title" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">Author</label>
                    <input class="form-control" type="text" placeholder="Enter Author" asp-for="Author">
                    <span asp-validation-for="Author" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">Description</label>
                    <textarea class="form-control" type="text" placeholder="Enter Description" asp-for="Description"></textarea>
                </div>
                <div>
                    <label class="form-label mt-4">ISBN</label>
                    <input class="form-control" type="text" placeholder="Enter ISBN" asp-for="ISBN" />
                    <span asp-validation-for="ISBN" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">List Price</label>
                    <input class="form-control" type="number" placeholder="Enter the List Price" asp-for="ListPrice" />
                    <span asp-validation-for="ListPrice" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">Price 1-50</label>
                    <input type="number" class="form-control" placeholder="Enter the 1-50 Price" asp-for="Price" />
                    <span asp-validation-for="Price" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">Price 50+</label>
                    <input type="number" class="form-control" placeholder="Enter the 50+ Price" asp-for="Price50" />
                    <span asp-validation-for="Price50" class="text-danger mt-1"></span>
                </div>
                <div>
                    <label class="form-label mt-4">Price 100+</label>
                    <input type="number" class="form-control" placeholder="Enter the 100 Price" asp-for="Price100" />
                    <span asp-validation-for="Price100" class="text-danger mt-1"></span>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary me-2">Submit</button>
                    <a class="btn btn-light" asp-action="Index">Back to list</a>
                </div>
            </fieldset>
        </form>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}