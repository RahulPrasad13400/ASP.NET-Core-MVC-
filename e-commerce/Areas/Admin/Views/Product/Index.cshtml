@model List<e_commerce.Models.Models.Product>

<partial name="_Notification" />

<div>
    <div class="d-flex justify-content-between">
        <h1>
            <span class="me-2">
                Product List
            </span>
            <i class="bi bi-apple"></i>
        </h1>
        <a class="btn btn-dark text-white text-center align-content-center rounded-1" asp-action="Create">
            <span class="me-2">
                Create Product
            </span>
            <i class="bi bi-balloon-fill"></i>
        </a>
    </div>
    <div class="mt-5">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>ISBN</th>
                    <th>Price</th>
                    <th>Author</th>
                    <th>Category</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.Title</td>
                        <td>@product.ISBN</td>
                        <td>@product.Price</td>
                        <td>@product.Author</td>
                        <td></td>
                        <td>
                            <a asp-action="Edit" class="btn btn-outline-success rounded-2 me-2" asp-route-id="@product.Id">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <a class="btn btn-outline-danger rounded-2" asp-action="Delete" asp-route-id="@product.Id">
                                <i class="bi bi-trash3"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>